generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  FARMER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PACKING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  UPI
  CARD
  NET_BANKING
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String?
  name         String
  password     String
  role         UserRole @default(CUSTOMER)
  imageUrl     String?
  location     String?
  lat          Float?
  lng          Float?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  farmer       Farmer?
  orders       Order[]
  cartItems    CartItem[]

  @@index([email])
  @@index([role])
}

model Farmer {
  id            String   @id @default(cuid())
  userId        String   @unique
  farmName      String
  description   String
  story         String?
  imageUrl      String?
  coverUrl      String?
  phone         String
  address       String
  lat           Float?
  lng           Float?
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  certifications String[]
  deliveryRadius Int     @default(20)
  minOrder      Float    @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products     Product[]
  orders       Order[]

  @@index([lat, lng])
}

model Product {
  id          String   @id @default(cuid())
  farmerId    String
  name        String
  category    String
  description String
  price       Float
  unit        String
  quantity    Float
  emoji       String   @default("🥕")
  imageUrl    String?
  organic     Boolean  @default(true)
  inSeason    Boolean  @default(true)
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farmer      Farmer     @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@index([farmerId])
  @@index([category])
  @@index([name])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Float    @default(1)
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Order {
  id              String        @id @default(cuid())
  orderNo         String        @unique
  customerId      String
  farmerId        String
  status          OrderStatus   @default(PENDING)
  items           OrderItem[]
  totalAmount     Float
  deliveryAddress String
  customerPhone   String
  customerName    String
  notes           String?
  paymentMethod   PaymentMethod @default(COD)
  paymentStatus   PaymentStatus @default(PENDING)
  razorpayOrderId String?
  deliveredAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer  User   @relation(fields: [customerId], references: [id])
  farmer    Farmer @relation(fields: [farmerId], references: [id])

  @@index([customerId])
  @@index([farmerId])
  @@index([status])
  @@index([orderNo])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  productName String
  productEmoji String
  price     Float
  quantity  Float
  unit      String

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}
